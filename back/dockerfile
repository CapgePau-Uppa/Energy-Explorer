FROM python:3.14-slim

# Install GDAL system deps (required for rasterio)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gdal-bin \
    libgdal-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy app code
COPY . .

# Non-root user (security best practice)
RUN useradd -m appuser && chown -R appuser /app
USER appuser

ENV SOLAR_DATASET_PATH=/app/data/solar.tif
ENV WIND_DATASET_PATH=/app/data/wind.tif


EXPOSE 5051

# Use gunicorn for production instead of Flask dev server
CMD ["gunicorn", "--bind", "0.0.0.0:5051", "--workers", "1", "app:app"]
